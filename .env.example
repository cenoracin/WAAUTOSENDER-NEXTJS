# Database MongoDB - Railway akan auto-generate
DATABASE_URL=mongodb+srv://username:password@cluster.mongodb.net/waautosender?retryWrites=true&w=majority

# NextAuth - Generate dengan: openssl rand -base64 32
NEXTAUTH_SECRET=your_secret_key_here_min_32_characters
NEXTAUTH_URL=https://your-railway-url.railway.app

# Node Environment
NODE_ENV=production

# App Config
NEXT_PUBLIC_APP_URL=https://your-railway-url.railway.app

# WhatsApp Config
WA_SESSION_DIR=/tmp/wa_sessions
WA_HEADLESS=true

# Port - Railway akan set otomatis
PORT=3000

# Optional: Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
